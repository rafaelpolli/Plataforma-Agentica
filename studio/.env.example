# Studio environment overrides.
# Copy to .env.local for local builds, or configure in your hosting
# provider's dashboard (Cloudflare Pages → Settings → Environment vars).

# Engine base URL.
#   - Local dev (vite dev server): leave unset; vite.config.ts proxies /api → localhost:8000
#   - Production builds: set to the public URL of your hosted engine
#       e.g. https://agents-engine.yourdomain.com
#       e.g. https://you-agents-engine.hf.space
VITE_API_BASE=
