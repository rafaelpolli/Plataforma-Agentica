ec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_node_ingest_pipeline","label":"Node Type: ingest_pipeline","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_node_condition","label":"Node Type: condition","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_node_loop","label":"Node Type: loop","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_node_cache","label":"Node Type: cache","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_node_logger","label":"Node Type: logger","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_project_json_versioning","label":"project.json Schema Versioning","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§14","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_auth_cognito","label":"Authentication: Amazon Cognito","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_auth_sso","label":"Authentication: Corporate SSO (SAML/OIDC)","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_hitl_dynamodb_checkpointer","label":"HITL DynamoDB Checkpointer Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3, §7.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"Without a persistent DynamoDB checkpointer, LangGraph interrupt() cannot persist state and the workflow cannot resume after human approval. Compiler auto-injects DynamoDBSaver when HITL nodes are present; graphs without HITL must omit the checkpointer to avoid unnecessary DynamoDB calls."},{"id":"spec_athena_parameterization_invariant","label":"Athena Parameterization Security Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"SQL injection prevention: only ? positional placeholders via Athena ExecutionParameters are allowed. String-formatted queries are explicitly prohibited by the compiler."},{"id":"spec_condition_expression_invariant","label":"Condition Expression Language Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"eval()-based Python is prohibited to prevent arbitrary code execution from the canvas. Only jmespath (read-only traversal) and cel (sandboxed CEL) are supported."},{"id":"spec_secrets_lazy_cache_invariant","label":"Lazy lru_cache Secrets Fetching Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§16.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"Secrets fetched lazily via functools.lru_cache, never at module import time. Avoids Secrets Manager API calls on every Lambda cold start; cache persists across warm invocations."},{"id":"spec_oauth2_token_cache_invariant","label":"OAuth2 Token Near-Expiry Cache Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"OAuth2 tokens for tool_http cached via lru_cache keyed on expiry, refreshed 60 seconds before expiry. Token never stored in state or logs."},{"id":"spec_per_tool_lambda_iam_invariant","label":"Per-Tool Lambda + IAM Role Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§9.2, §16.1","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"Each tool node generates exactly one Lambda with its own least-privilege IAM role. No shared execution roles across tools or agents. No wildcard resource ARNs."},{"id":"spec_bedrock_only_v1","label":"Bedrock-Only LLM for v1","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§1","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"Amazon Bedrock is the sole LLM provider in v1. Architecture is designed to be provider-agnostic via LangChain abstractions to allow future extensibility to OpenAI, Vertex AI, etc."},{"id":"spec_inference_profile_precedence","label":"inference_profile_arn Precedence over model_id","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"When inference_profile_arn is set on agent or tool_bedrock nodes, it takes precedence over model_id. Required for cross-region inference when model is unavailable in deployment region."},{"id":"spec_loop_send_api_invariant","label":"Loop Node Send API Compilation Invariant","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"Loop node compiles to LangGraph Send API fan-out/fan-in. item and results ports are two separate subgraph edges; a downstream node cannot be wired to both simultaneously."},{"id":"spec_single_tenant","label":"Single-Tenant Design Decision","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§1","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"No multi-workspace, no RBAC in v1. Simplifies auth, data isolation, and deployment model."},{"id":"spec_cache_dynamodb_only_v1","label":"Cache Node DynamoDB-Only in v1","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§5.3, §18","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null,"rationale":"ElastiCache (Redis) deferred from v1 due to added VPC infrastructure complexity. DynamoDB used as sole cache backend."},{"id":"spec_project_json","label":"project.json Re-import Schema","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§14","source_url":null,"captured_at":"2026-05-04","author":null,"contributor":null},{"id":"spec_langgraph","label":"LangGraph (Agent Framework)","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§8.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_langchain","label":"LangChain (LLM Abstractions)","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§8.3","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_agentcore","label":"Amazon AgentCore","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§9","source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"spec_bedrock","label":"Amazon Bedrock","file_type":"rationale","source_file":"generative-agents-platform-spec.md","source_location":"§9.2","source_url":null,"captured